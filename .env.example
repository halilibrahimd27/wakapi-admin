# =====================================================================
# Wakapi Self-Hosted — Ortam Değişkenleri (Şablon)
# =====================================================================
# Bu dosyayı .env olarak kopyalayın ve değerleri kendi ortamınıza göre
# doldurun. .env dosyası git'e commit ETMEYİN (.gitignore'da hariç tutulur).
# =====================================================================

# ─── Wakapi Çekirdek ──────────────────────────────────────────────────
# Şifre hash salt. Production'da rastgele uzun bir string olmalı.
#   openssl rand -base64 48
WAKAPI_PASSWORD_SALT=change-me-to-a-random-string

# Public erişim URL'i (reverse proxy arkasında gerçek HTTPS adresi)
WAKAPI_PUBLIC_URL=http://localhost:3000

# ─── PostgreSQL ───────────────────────────────────────────────────────
# Hem ana DB parolası hem pgAdmin/admin servislerinin bağlandığı parola.
WAKAPI_DB_PASSWORD=change-me-strong-password

# ─── pgAdmin ──────────────────────────────────────────────────────────
PGADMIN_DEFAULT_EMAIL=admin@example.com
PGADMIN_DEFAULT_PASSWORD=change-me-pgadmin-password

# ─── Grafana ──────────────────────────────────────────────────────────
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=change-me-grafana-password
GF_SERVER_ROOT_URL=http://localhost:3001

# ─── Sentry (opsiyonel — hata izleme) ─────────────────────────────────
# Devre dışı bırakmak için boş bırakın.
WAKAPI_SENTRY_DSN=
WAKAPI_SENTRY_TRACING=false
WAKAPI_SENTRY_SAMPLE_RATE=0.1
WAKAPI_SENTRY_SAMPLE_RATE_HEARTBEATS=0.05

# ─── Mail / SMTP (opsiyonel — şifre sıfırlama, davet kodu) ────────────
WAKAPI_MAIL_ENABLED=false
WAKAPI_MAIL_SENDER=no-reply@example.com
WAKAPI_MAIL_SMTP_HOST=
WAKAPI_MAIL_SMTP_PORT=587
WAKAPI_MAIL_SMTP_USER=
WAKAPI_MAIL_SMTP_PASS=
WAKAPI_MAIL_SMTP_TLS=true
